# GAS worker — variables de entorno.
# Copia a .env y rellena los valores reales. NUNCA subas .env al repo.

# --- Supabase (usa la service_role: el worker salta RLS) ---
SUPABASE_URL=https://ftpgnimyjxlomjfdqfqy.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- Apify ---
APIFY_TOKEN=
APIFY_EMPLOYEES_ACTOR_ID=Vb6LZkh4EqRlR0Ka9
APIFY_COMPANY_URL_FINDER_ACTOR_ID=9X6Pju8NeHNTvzRxF
APIFY_SERP_ACTOR_ID=

# --- OpenRouter (Paso 2: validación de URL con Gemini + web search; Paso 3: verify por LLM) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-3.1-flash-lite-preview
OPENROUTER_APP_TITLE=GAS Scraper
OPENROUTER_REFERER=
OPENROUTER_WEB_MAX_RESULTS=3
VERIFY_LLM_MAX_TOKENS=400

# --- HarvestAPI REST (Paso 3: enriquecer UN perfil para verify). Clave DISTINTA del APIFY_TOKEN ---
HARVEST_API_KEY=
HARVEST_API_BASE_URL=https://api.harvest-api.com

# --- Búsqueda de empleados ---
SEARCH_MAX_PER_COMPANY=3

# --- Storage ---
RESULTS_BUCKET=resultados

# --- Loop del worker ---
POLL_INTERVAL_SECONDS=5
